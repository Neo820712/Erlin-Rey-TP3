{
  "permissions": {
    "allow": [
      "Bash(uv sync)",
      "Bash(uv run pytest *)",
      "Bash(uv run uvicorn backend.main:app *)",
      "Bash(uv run python scripts/seed.py)",
      "Bash(uv run python scripts/generar_senal.py *)",
      "Bash(python -m http.server *)",
      "Bash(curl http://localhost:8000/*)",
      "Bash(git status*)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git branch *)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git push origin *)",
      "Bash(ls *)",
      "Bash(cat *)"
    ],
    "deny": [
      "Bash(rm -r*)",
      "Bash(rm --recursive *)",
      "Bash(git reset *)",
      "Bash(git push * -f*)",
      "Bash(git push * --force*)",
      "Bash(git push * +*)",
      "Bash(git clean *)",
      "Bash(uv add *)",
      "Bash(pip install *)",
      "Bash(curl * -o*)",
      "Bash(curl * -O*)",
      "Bash(sudo *)",
      "Bash(doas *)"
    ]
  },
  "env": {
    "DATABASE_URL": "sqlite:///./data/activos.db",
    "CORS_ORIGINS": "http://localhost:3000",
    "PYTHONPATH": "."
  }
}