{
  "permissions": {
    "allow": [
      "Bash(uv sync)",
      "Bash(uv add *)",
      "Bash(uv run pytest *)",
      "Bash(uv run uvicorn *)",
      "Bash(uv run python scripts/*)",
      "Bash(uvicorn backend.main:app *)",
      "Bash(python -m http.server *)",
      "Bash(python scripts/*)",
      "Bash(curl http://localhost:*)",
      "Bash(git status*)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git branch *)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git push origin *)",
      "Bash(ls *)",
      "Bash(cat *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r -f *)",
      "Bash(rm -Rf *)",
      "Bash(rm --recursive *)",
      "Bash(git reset --hard*)",
      "Bash(git reset --keep*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -df*)",
      "Bash(git clean -fdx*)",
      "Bash(git clean -dfx*)",
      "Bash(pip install *)",
      "Bash(uv pip install *)",
      "Bash(sudo *)",
      "Bash(sudo)",
      "Bash(doas *)"
    ]
  },
  "env": {
    "DATABASE_URL": "sqlite:///./data/activos.db",
    "CORS_ORIGINS": "http://localhost:3000",
    "PYTHONPATH": "."
  }
}
